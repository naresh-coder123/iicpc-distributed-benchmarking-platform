# Copy this file to .env and fill in values for local development.
# Never commit .env to source control.

# ── Infrastructure ────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=metrics
KAFKA_GROUP=telemetry_ingester
PG_URL=postgres://postgres:postgres@localhost:5432/iicpc?sslmode=disable

# ── Python mock matcher ───────────────────────────────────────────────────────
MOCK_MATCHER_ADDR=0.0.0.0:50051

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Set these before `npm run dev` or building the Docker image.
NEXT_PUBLIC_API_BASE=http://localhost:8080
NEXT_PUBLIC_JUDGE_BASE=http://localhost:8081
