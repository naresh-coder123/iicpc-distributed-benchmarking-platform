# ##############################################################################
# IICPC Platform — Environment Variables Reference
# Copy to .env and fill in your actual values.
# ##############################################################################

# ── Private Infrastructure (Internal K8s DNS Communication) ───────────────────
REDIS_ADDR=redis.iicpc-telemetry.svc.cluster.local:6379
KAFKA_BROKERS=redpanda.iicpc-telemetry.svc.cluster.local:9092
KAFKA_TOPIC=metrics
KAFKA_GROUP=telemetry_ingester
PG_URL=postgres://postgres:postgres@timescaledb.iicpc-telemetry.svc.cluster.local:5432/iicpc?sslmode=disable

# ── Internal Service Routing ──────────────────────────────────────────────────
# judge-api is now ClusterIP (no public IP). leaderboard-api proxies it.
JUDGE_INTERNAL_URL=http://judge-api.iicpc-runner.svc.cluster.local:8081

# ── CORS Security ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins (no trailing slash).
# ⚠️  Patch this AFTER first deploy once you have the leaderboard-ui External IP:
#   kubectl get svc leaderboard-ui -n iicpc-frontend -o jsonpath='{.status.loadBalancer.ingress[0].ip}'
# Then set: ALLOWED_ORIGINS=http://<that-ip>
# Leave empty during initial deploy to fall back to wildcard (*)
ALLOWED_ORIGINS=

# ── Core Runner Routing ───────────────────────────────────────────────────────
MOCK_MATCHER_ADDR=mock-matcher.iicpc-runner.svc.cluster.local:50051

# ── Frontend Public Endpoints (Your Live Azure IPs) ───────────────────────────
# ⚠️  After first deploy, get the IPs with:
#   kubectl get svc -n iicpc-frontend
# Then rebuild and re-push the leaderboard-ui image with these values set.

# The leaderboard REST/SSE API (Public IP #2 after control plane):
NEXT_PUBLIC_API_BASE=http://<20.235.205.251>:8080

# Judge API is accessed via /proxy/judge on leaderboard-api (same Public IP).
# Set NEXT_PUBLIC_JUDGE_BASE ONLY if you want to override the automatic proxy routing,
# e.g. for local Docker Compose development against a direct judge-api port.
# NEXT_PUBLIC_JUDGE_BASE=http://<YOUR_LEADERBOARD_API_EXTERNAL_IP>:8080/proxy/judge